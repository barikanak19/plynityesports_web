# Copy to .env in the project root and restart the Vite dev server after changes.
# Production builds also load .env.production (committed with public Cashfree App ID).
# On Vercel, you can override these under Project Settings → Environment Variables.

# Cashfree public App ID (safe for frontend — never put Secret Key here)
VITE_CASHFREE_APP_ID=13222203096e7c0312ae17db59e0222231

# sandbox | production — must match your Cashfree credentials
VITE_CASHFREE_ENV=production

# Server-only Cashfree credentials for Vercel Functions (/api/cashfree/*)
# Set these in Vercel → Project Settings → Environment Variables (no VITE_ prefix)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=production

# Google Sheets webhook URLs (one per tournament sheet)
VITE_BGMI_SOLO_FRIDAY=
VITE_BGMI_DUO_FRIDAY=
VITE_BGMI_SOLO_SATURDAY=
VITE_BGMI_SQUAD_SATURDAY=
VITE_BGMI_SOLO_SUNDAY=
VITE_BGMI_SQUAD_SUNDAY=
VITE_FF_SOLO_FRIDAY=
VITE_FF_DUO_FRIDAY=
VITE_FF_SOLO_SATURDAY=
VITE_FF_SQUAD_SATURDAY=
VITE_FF_SOLO_SUNDAY=
VITE_FF_SQUAD_SUNDAY=
